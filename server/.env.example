# Environment configuration file
# Copy this to .env and fill in your values

# WiFi Configuration (ESP32)
WIFI_SSID=YOUR_SSID
WIFI_PASSWORD=YOUR_PASSWORD

# Server Configuration
SERVER_HOST=0.0.0.0
SERVER_PORT=5000
SERVER_URL=http://localhost:5000

# Database
DATABASE_PATH=./database/parking_system.db
DATABASE_TYPE=sqlite3

# Parking System Configuration
TOTAL_PARKING_SLOTS=6
PARKING_FEE_PER_HOUR=50000
GRACE_PERIOD_MINUTES=5
GATE_AUTO_CLOSE_TIME_SECONDS=5

# Sensor Thresholds
SMOKE_THRESHOLD=300
FLAME_DETECTION_VALUE=1

# Arduino Configuration
ARDUINO_BAUD_RATE=115200
ARDUINO_UART=1

# ESP32 Configuration
ESP32_BAUD_RATE=19200
ESP32_UART=2

# Development
NODE_ENV=development
DEBUG=true

# API Keys (if needed)
API_KEY=your_secret_key_here
